{
  "expo": {
    "name": "Pocket Wallet",
    "slug": "pocket-wallet-solana",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/app-icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pocketwallet.app"
    },
    "android": {
      "package": "com.pocketwallet.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#1a1a2e"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-localization"
    ],
    "scheme": "pocket-wallet",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3244a743-128f-4712-93fd-2599073f5c0d"
      }
    }
  }
}
